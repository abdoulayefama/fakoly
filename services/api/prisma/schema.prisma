generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Country {
  id        String   @id @default(cuid())
  code      String   @unique // ex: GN
  name      String
  currency  String   // ex: GNF
  isActive  Boolean  @default(true)

  flags     FeatureFlag[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

enum FeatureKey {
  MOBILITY_MOTO
  MOBILITY_CAR
  MOBILITY_TRICYCLE
  DELIVERY_PARCEL
  FOOD
  MARKETPLACE
  CARPOOL
}

model FeatureFlag {
  id        String     @id @default(cuid())
  countryId String
  key       FeatureKey
  enabled   Boolean    @default(false)

  country   Country    @relation(fields: [countryId], references: [id], onDelete: Cascade)

  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt

  @@unique([countryId, key])
  @@index([countryId])
}

enum AuditAction {
  FEATURE_FLAG_SET
}

model AuditLog {
  id        String      @id @default(cuid())
  action    AuditAction
  actor     String      // ex: "internal_api" puis "admin:<id>"
  countryId String?
  entity    String      // ex: "FeatureFlag"
  entityId  String?
  before    Json?
  after     Json?
  ip        String?
  userAgent String?
  createdAt DateTime    @default(now())

  @@index([action])
  @@index([countryId])
  @@index([createdAt])
}