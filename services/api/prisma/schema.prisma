generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Country {
  id       String  @id @default(cuid())
  code     String  @unique // ex: GN
  name     String
  currency String // ex: GNF
  isActive Boolean @default(true)

  timezone      String  @default("Africa/Conakry")
  defaultLocale String  @default("fr-GN")
  callingCode   String? // ex: +224

  flags    FeatureFlag[]
  settings CountrySettings?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model CountrySettings {
  id        String @id @default(cuid())
  countryId String @unique

  // Map & Geo
  mapProvider       String  @default("mapbox") // "mapbox" | "osm"
  mapboxPublicToken String?
  mapStyleUrl       String?

  // Business defaults (V1)
  defaultCommissionBps Int     @default(1500) // 15%
  vatEnabled           Boolean @default(false)
  vatRateBps           Int     @default(0)

  // Support
  supportPhone String?
  supportEmail String?

  country Country @relation(fields: [countryId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

enum FeatureKey {
  MOBILITY_MOTO
  MOBILITY_CAR
  MOBILITY_TRICYCLE
  DELIVERY_PARCEL
  FOOD
  MARKETPLACE
  CARPOOL
}

model FeatureFlag {
  id        String     @id @default(cuid())
  countryId String
  key       FeatureKey
  enabled   Boolean    @default(false)

  country Country @relation(fields: [countryId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([countryId, key])
  @@index([countryId])
}

enum AuditAction {
  FEATURE_FLAG_SET
  COUNTRY_CREATED
  COUNTRY_UPDATED
  COUNTRY_ACTIVATED
  COUNTRY_DEACTIVATED
  COUNTRY_SETTINGS_UPDATED
}

model AuditLog {
  id        String      @id @default(cuid())
  action    AuditAction
  actor     String // ex: "internal_api" puis "admin:<id>"
  countryId String?
  entity    String // ex: "FeatureFlag"
  entityId  String?
  before    Json?
  after     Json?
  ip        String?
  userAgent String?
  createdAt DateTime    @default(now())

  @@index([action])
  @@index([countryId])
  @@index([createdAt])
}

model AdminUser {
  id           String  @id @default(cuid())
  email        String? @unique
  phone        String? @unique
  passwordHash String
  fullName     String?
  isActive     Boolean @default(true)

  roles    AdminUserRole[]
  sessions AdminSession[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model AdminRole {
  id       String  @id @default(cuid())
  code     String  @unique // ex: SUPER_ADMIN, COUNTRY_ADMIN, SUPPORT
  name     String
  isActive Boolean @default(true)

  users AdminUserRole[]
  perms AdminRolePermission[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model AdminPermission {
  id        String                @id @default(cuid())
  code      String                @unique // ex: FEATURE_FLAGS_WRITE, AUDIT_READ
  name      String
  createdAt DateTime              @default(now())
  rolePerms AdminRolePermission[]
}

model AdminUserRole {
  id     String @id @default(cuid())
  userId String
  roleId String

  user AdminUser @relation(fields: [userId], references: [id], onDelete: Cascade)
  role AdminRole @relation(fields: [roleId], references: [id], onDelete: Cascade)

  @@unique([userId, roleId])
  @@index([userId])
  @@index([roleId])
}

model AdminRolePermission {
  id           String @id @default(cuid())
  roleId       String
  permissionId String

  role       AdminRole       @relation(fields: [roleId], references: [id], onDelete: Cascade)
  permission AdminPermission @relation(fields: [permissionId], references: [id], onDelete: Cascade)

  @@unique([roleId, permissionId])
  @@index([roleId])
  @@index([permissionId])
}

model AdminSession {
  id          String    @id @default(cuid())
  userId      String
  refreshHash String
  revokedAt   DateTime?
  expiresAt   DateTime

  user AdminUser @relation(fields: [userId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@index([userId])
  @@index([expiresAt])
}
